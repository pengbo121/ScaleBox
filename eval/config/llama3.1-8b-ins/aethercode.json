{
  "AetherCode": {
    "datasetType": "AetherCodeDataset",
    "datasets": [
      {
        "id": "aethercode_cpp",
        "dataset": "aethercode_cpp",
        "version": "v1_2024"
      }
    ],
    "infer_parameters": [
      {
        "model_path": "meta-llama/Llama-3.1-8B-Instruct",
